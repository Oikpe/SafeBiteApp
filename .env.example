# ─── SafeBite Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control — it contains secrets.

# Supabase configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI configuration
# Set to "false" to use the real AI endpoint (FastAPI model backend).
# Keep "true" for development/demo with mock data.
VITE_USE_MOCK_AI=true

# Model API (FastAPI) base URL
# Use /api to route through Vite dev proxy (see vite.config.ts)
VITE_MODEL_API_URL=/api

# ─── Model Backend Only (model/.env) ──────────────────────────────────────────
# These vars are needed by model/main.py, NOT the frontend.
# Create a separate model/.env file with:
#   SUPABASE_URL=https://your-project-id.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#   HF_TOKEN=your-huggingface-token
