# ─── SafeBite Model Backend ────────────────────────────────────────────────────
# Copy this file to model/.env and fill in your values.
#
# For HuggingFace Spaces deployment, set these as Secrets
# in Space Settings → Variables and secrets.

# Supabase connection (use service_role key for server-side operations)
SUPABASE_URL=https://zquoepuaofuwxskggqdz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# HuggingFace API token (needs Inference API access)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
